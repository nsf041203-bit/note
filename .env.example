# ModelScope API Key
# 注册地址: https://www.modelscope.cn/
MODELSCOPE_API_KEY=your_api_key_here

# 可选: 指定 Whisper 模型大小 (tiny/base/small/medium/large)
# 推荐 base (精度与速度平衡), 中文可用 medium 提升准确率
WHISPER_MODEL=base

# 可选: ModelScope 推理模型
MODELSCOPE_MODEL=Qwen/Qwen2.5-72B-Instruct

# 可选: 代理地址（如使用 VPN/Clash，常见端口 7890）
# 出现 "Connection error" 或 SSL 握手失败时可尝试配置
# HTTPS_PROXY=http://127.0.0.1:7890

# 可选: 关闭 SSL 验证（公司/学校网络有 HTTPS 拦截导致连接失败时设为 false）
# SSL_VERIFY=false
